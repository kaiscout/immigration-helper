{
  "expo": {
    "name": "Immigration Helper",
    "slug": "immigration-helper",
    "owner": "deniropro",
    "version": "1.0.0",
    "description": "Private immigration checklist, reminders, and official resources.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "immigrationhelper",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.denizizci.immigrationhelper",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.denizizci.immigrationhelper",
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1d9691d7-a4b4-4182-b813-12442ed5168c"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#2563EB",
          "defaultChannel": "immigration-reminders",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ]
  }
}

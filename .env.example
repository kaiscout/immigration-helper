# Production option for App Store / Play Store builds.
# Point this at your own backend endpoint that calls OpenAI with a server-side secret.
EXPO_PUBLIC_AI_PROXY_URL=
# Public app access token paired with AI_PROXY_CLIENT_TOKEN on the server.
# This is an abuse deterrent, not a substitute for the private OpenAI key.
EXPO_PUBLIC_AI_CLIENT_TOKEN=

# Public RevenueCat SDK keys for store builds.
# These are not secret, but they must be configured in EAS before production builds.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_PLUS_ENTITLEMENT_ID=immigration_helper_plus
EXPO_PUBLIC_PLUS_MONTHLY_PRODUCT_ID=immigration_helper_plus_monthly
EXPO_PUBLIC_PLUS_YEARLY_PRODUCT_ID=immigration_helper_plus_yearly
EXPO_PUBLIC_FREE_AI_QUESTION_LIMIT=5

# Server-only settings for `npm run ai:server`.
# Never prefix the private server key with EXPO_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
USCIS_VECTOR_STORE_ID=
AI_PROXY_CLIENT_TOKEN=
REQUIRE_AI_GENERATION=false
REQUIRE_CLIENT_TOKEN=true
PORT=8787
ALLOWED_ORIGIN=*

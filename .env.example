# Local Expo Go testing only.
# This value is bundled into the client app, so do not use it for public App Store builds.
EXPO_PUBLIC_OPENAI_API_KEY=

# Optional. Keep the default unless you intentionally choose another model.
EXPO_PUBLIC_OPENAI_MODEL=gpt-5.4-mini

# Production option for App Store / Play Store builds.
# Point this at your own backend endpoint that calls OpenAI with a server-side secret.
EXPO_PUBLIC_AI_PROXY_URL=

# Server-only settings for `npm run ai:server`.
# Never prefix the private server key with EXPO_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
USCIS_VECTOR_STORE_ID=
PORT=8787
ALLOWED_ORIGIN=*

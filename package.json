{
  "name": "immigration-helper",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/start-project.js",
    "stop": "node ./scripts/stop-expo.js",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android --clear",
    "ios": "expo start --ios --clear",
    "web": "expo start --web --clear",
    "lint": "eslint App.js index.js components/**/*.js constants/**/*.js data/**/*.js screens/**/*.js i18n/**/*.js",
    "check:ai": "node ./scripts/check-ai-config.js",
    "setup:ai-key": "node ./scripts/setup-ai-key.js",
    "test:uscis": "node --test tests/uscis-config.test.mjs",
    "test:ai": "node --test tests/ai-answer.test.mjs",
    "test:ai-intent": "node --test tests/ai-intent.test.mjs",
    "test:localization": "node --test tests/localization.test.mjs",
    "test:privacy": "node --test tests/privacy-consent.test.mjs",
    "uscis:plan": "node ./scripts/scrape-uscis.mjs --dry-run",
    "uscis:scrape": "node ./scripts/scrape-uscis.mjs",
    "uscis:package": "node ./scripts/package-uscis-corpus.mjs",
    "ai:server": "node --env-file-if-exists=.env ./server/index.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.0",
    "expo": "~54.0.25",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.12",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.8",
    "htmlparser2": "^10.1.0",
    "i18next": "^25.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.2.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^10.3.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  },
  "private": true
}

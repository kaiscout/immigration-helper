{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "App.js",
    "index.js",
    "constants/**/*.js",
    "data/**/*.js",
    "data/**/*.json",
    "i18n/**/*.js",
    "i18n/**/*.json",
    "screens/**/*.js"
  ]
}
